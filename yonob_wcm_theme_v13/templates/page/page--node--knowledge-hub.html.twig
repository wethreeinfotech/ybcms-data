{% include directory ~ '/templates/layout/header.html.twig' %}

<main class="du-main-section">
  <div class="l3-banner-blue container-fluid">
    <div class="container-xl p-4">
      <nav class="custom-breadcrumb" aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
          <li class="breadcrumb-item"><a href="{{ url('<front>') }}">Home</a></li>
          <li class="breadcrumb-item"><a href="{{ url('<front>') }}knowledge-hub">Knowledge Hub</a></li>
          {# <li class="breadcrumb-item active" aria-current="page">{{current_node.title.value }}</li> #}
          <li class="breadcrumb-item active" aria-current="page">Category Article</li>
        </ol>
      </nav>
    </div>
  </div>

  <main class="container-xl">
    <div class="row g-5 mt-0">
      <div class="col-lg-8">
        {# Outputs the node content via node--knowledge-hub.html.twig + Drupal messages and tabs #}
        {{ page.highlighted }}
        {{ page.content }}
      </div>

      <div class="col-lg-4 pe-lg-0">
        <div class="position-sticky" style="top: 11rem;">
          
          {# LATEST ARTICLES #}
          {% if latest_articles|length > 0 %}
          <div class="article-right-side mb-5">
            <h3 class="article-lead-title mb-4">Latest Articles</h3>
            <div class="row row-cols-1 g-0">
              {% for item in latest_articles %}
              <div class="col">
                <a href="{{ path('entity.node.canonical', {'node': item.id()}) }}" class="card mb-4 border-0 bg-transparent text-decoration-none">
                  <div class="row g-3">
                    <div class="col-4 col-md-5">
                      <img src="{{ item.field_thumbnail_image.entity.uri.value ? file_url(item.field_thumbnail_image.entity.uri.value) : base_path ~ directory ~ '/images/articles/latest-articles/article-default.png' }}"
                           class="img-fluid rounded-3" style="object-fit: cover; width: 100%; height: 100%; min-height: 90px;" alt="{{ item.title.value }}">
                    </div>
                    <div class="col-8 col-md-7">
                      <h6 class="text-dark fw-bold mb-2" style="font-size: 1rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">{{ item.title.value }}</h6>
                      <div class="text-secondary mb-3" style="font-size: 0.85rem; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">{{ item.field_short_description.value|striptags }}</div>
                      <div class="text-secondary mt-auto" style="font-size: 0.8rem;">Published on : {{ item.field_published_on.value|date('d F Y') }}</div>
                    </div>
                  </div>
                </a>
              </div>
              {% endfor %}
            </div>
          </div>
          {% endif %}

          {# RELATED ARTICLES #}
          {% if related_articles|length > 0 %}
          <div class="article-right-side mb-5" style="display: none;">
            <h3 class="article-lead-title mb-4">Related Articles</h3>
            <div class="row row-cols-1 g-0">
              {% for item in related_articles %}
              <div class="col">
                <a href="{{ path('entity.node.canonical', {'node': item.id()}) }}" class="card mb-4 border-0 bg-transparent text-decoration-none">
                  <div class="row g-3">
                    <div class="col-4 col-md-5">
                      <img src="{{ item.field_thumbnail_image.entity.uri.value ? file_url(item.field_thumbnail_image.entity.uri.value) : base_path ~ directory ~ '/images/articles/latest-articles/article-default.png' }}"
                           class="img-fluid rounded-3" style="object-fit: cover; width: 100%; height: 100%; min-height: 90px;" alt="{{ item.title.value }}">
                    </div>
                    <div class="col-8 col-md-7">
                      <h6 class="text-dark fw-bold mb-2" style="font-size: 1rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">{{ item.title.value }}</h6>
                      <div class="text-secondary mb-3" style="font-size: 0.85rem; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">{{ item.field_short_description.value|striptags }}</div>
                      <div class="text-secondary mt-auto" style="font-size: 0.8rem;">Published on : {{ item.field_published_on.value|date('d F Y') }}</div>
                    </div>
                  </div>
                </a>
              </div>
              {% endfor %}
            </div>
          </div>
          {% endif %}

          {# RELATED TAGS #}
          {% set tags = current_node.field_knowledge_hub_tags %}
          {% if tags and not tags.isEmpty() %}
          <div class="article-right-side mb-4" style="display: none;">
            <h3 class="article-lead-title mb-3">Related Tags</h3>
            <div class="row g-0 mb-4">
              <div class="col-12">
                <ul class="related-tag-list">
                  {% for tag in tags %}
                  <li><a href="javascript:void(0)" class="related-tag-btn">#{{ tag.entity.name.value }}</a></li>
                  {% endfor %}
                </ul>
              </div>
            </div>
          </div>
          {% endif %}

        </div>
      </div>
    </div>
    
    {# Outputs the FOOTER Paragraph in FULL WIDTH below the main content/sidebar row #}
    {% if not node.field_paragraphs_demo.isEmpty() %}
      {% for item in node.field_paragraphs_demo %}
        {% set paragraph = item.entity %}
        {% if paragraph and paragraph.bundle == 'footer' %}
          <div class="card article-contact-base mb-5">
              <div class="card-body">
                  <h5 class="contact-heading">Contact Details:</h5>
                  <div class="row mt-4">
                      <div class="col-md-6">
                          {{ paragraph.field_footer_left.value|raw }}
                      </div>
                      <div class="col-md-1 d-none d-md-flex contact-divider-base">
                          <span class="verticle-divider-line"></span>
                      </div>
                      <div class="col-md-5">
                          {{ paragraph.field_footer_right.value|raw }}
                          {% if node.field_social_account.value is not empty %}
                            <p class="mt-3">
                              <a target="_blank" href="https://x.com/{{ node.field_social_account.value }}" class="d-flex align-items-center">
                                <img src="{{ url('<front>') }}themes/custom/yonob_wcm_theme/images/x-twitter.svg" alt="X" class="me-2" style="width: 24px; height: 24px;">
                                @{{ node.field_social_account.value }}
                              </a>
                            </p>
                          {% endif %}
                      </div>
                  </div>
              </div>
          </div>
        {% endif %}
      {% endfor %}
    {% endif %}

  </main>
</main>

{% include directory ~ '/templates/layout/footer.html.twig' %}
