{# ============================================================ HEADER ===== #}
<article class="drupal-main">
<div id="header" class="du-header">
  <div id="prelogin-sbihome">
    <div class="container-fluid">
      <header id="revamp_topHeader" class="top-header">

        {# ── Global Bar ────────────────────────────────────────────── #}
        <div class="globalbar">
          <div class="container-xl">
            <div class="row m-md-0 m-y-sm-1 ms-sm-0">

              {# -- Accessibility / Language col -- #}
              <div class="col-12 col-xs-12 col-sm-12 col-md-5 col-lg-4 ps-lg-3 p-md-0 ps-sm-0">
                <div>
                  <div class="skip float-end float-md-start float-lg-start" onclick="test()">
                    <span class="d-none d-sm-block d-md-none d-lg-block">
                      <a href="javascript:void(0)" tabindex="0">{{ 'Skip to main content'|t }}</a>
                    </span>
                  </div>
                  <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="#">{{ 'Action'|t }}</a></li>
                    <li><a class="dropdown-item" href="#">{{ 'Another action'|t }}</a></li>
                    <li><a class="dropdown-item" href="#">{{ 'Something else here'|t }}</a></li>
                  </ul>
                </div>

                <div class="visibility float-start">
                  <ul>
                    <li><span><a tabindex="0" aria-label="{{ 'Reduce font size'|t }}" id="decreaseFont"> A- </a></span></li>
                    <li><span><a tabindex="0" aria-label="{{ 'Default font size'|t }}" id="resetFont"> A </a></span></li>
                    <li><span><a tabindex="0" aria-label="{{ 'Increase font size'|t }}" id="increaseFont"> A+ </a></span></li>
                  </ul>
                </div>

                <div id="" class="contrast float-start" onclick="Contrast_theme();">
                  <span><a tabindex="0" aria-label="{{ 'Change Contrast'|t }}" role="button"></a></span>
                </div>

                <div class="language float-start language-hide">
                  <div class="d-inline-block dropdown">
                    <span class="dropdown-toggle variant" aria-expanded="false">{{ 'English'|t }}</span>
                    <div class="calc-open dropdown-menu">
                      <ul>
                        <li>{{ 'English'|t }}</li>
                        <li>{{ 'Hindi'|t }}</li>
                        <li>{{ 'Marathi'|t }}</li>
                      </ul>
                    </div>
                  </div>
                </div>
              </div>{# /.col – accessibility #}

              {# -- SBI Connected (centre) -- #}
              <div class="col-12 col-md-7 col-lg-4 d-none d-md-block text-center position-relative p-0">
                <div tabindex="0" class="sbi-connected"
                    data-bs-toggle="collapse"
                    data-bs-target="#collapseDiv"
                    aria-expanded="false"
                    aria-controls="collapseDiv">{{ 'SBI Wealth, Insurance and more'|t }}</div>
              </div>

              <div class="collapse grow-your-wealth" id="collapseDiv">
                <div class="container-xl">
                  <div class="row row-cols-2 row-cols-sm-2 row-cols-md-3 row-cols-lg-5 g-4">
                    <div class="col">
                      <a target="_blank" tabindex="0" class="grow-card p-1"
                        href="https://sbi.bank.in/web/wealth-management/"
                        aria-label="Redirect to https://sbi.bank.in/web/wealth-management">
                        <div class="w-100">
                          <div class="grow-card-img"><img loading="lazy" src="{{ base_path ~ directory }}/images/header/sbi-wealth-gyw.png" alt="SBI Wealth" aria-description="SBI Wealth"></div>
                          <div class="grow-card-divider mx-2 my-1"></div>
                          <div class="grow-card-desc px-2 py-1 pb-3">{{ 'Explore a world of opportunities to meet your financial aspirations'|t }}</div>
                        </div>
                      </a>
                    </div>
                    <div class="col">
                      <a target="_blank" tabindex="0" class="grow-card p-1"
                        href="https://www.sbigeneral.in/product/corporate"
                        aria-label="Redirect to SBI General">
                        <div class="w-100">
                          <div class="grow-card-img"><img loading="lazy" src="{{ base_path ~ directory }}/images/header/sbi-general-gyw.png" alt="SBI General"></div>
                          <div class="grow-card-divider mx-2 my-1"></div>
                          <div class="grow-card-desc px-2 py-1 pb-3">{{ 'Simple and innovative solutions to build a sustainable business'|t }}</div>
                        </div>
                      </a>
                    </div>
                    <div class="col">
                      <a target="_blank" tabindex="0" class="grow-card p-1"
                        href="https://corporate.sbimf.com"
                        aria-label="Redirect to SBI Mutual Fund">
                        <div class="w-100">
                          <div class="grow-card-img"><img loading="lazy" src="{{ base_path ~ directory }}/images/header/sbi-mf-gyw.png" alt="SBI Mutual Fund"></div>
                          <div class="grow-card-divider mx-2 my-1"></div>
                          <div class="grow-card-desc px-2 py-1 pb-3">{{ 'Invest smartly, manage liquidity and fuel your business growth with mutual funds'|t }}</div>
                        </div>
                      </a>
                    </div>
                    <div class="col">
                      <a target="_blank" tabindex="0" class="grow-card p-1"
                        href="https://www.sbisecurities.in/corporate-demat-account"
                        aria-label="Redirect to SBI Securities">
                        <div class="w-100">
                          <div class="grow-card-img"><img loading="lazy" src="{{ base_path ~ directory }}/images/header/sbi-securities-gyw.png" alt="SBI Securities"></div>
                          <div class="grow-card-divider mx-2 my-1"></div>
                          <div class="grow-card-desc px-2 py-1 pb-3">{{ 'Achieve your financial goals and take your investments to new heights'|t }}</div>
                        </div>
                      </a>
                    </div>
                    <div class="col">
                      <a target="_blank" tabindex="0" class="grow-card p-1"
                        href="https://www.sbilife.co.in/en/group-insurance/corporate-plans"
                        aria-label="Redirect to SBI Life">
                        <div class="w-100">
                          <div class="grow-card-img"><img loading="lazy" src="{{ base_path ~ directory }}/images/header/sbi-life-gyw.png" alt="SBI Life"></div>
                          <div class="grow-card-divider mx-2 my-1"></div>
                          <div class="grow-card-desc px-2 py-1 pb-3">{{ 'Secure your future with a wide range of life insurance solutions'|t }}</div>
                        </div>
                      </a>
                    </div>
                    <div class="col">
                      <a target="_blank" tabindex="0" class="grow-card p-1"
                        href="https://www.sbicard.com/en/corporate.page"
                        aria-label="Redirect to SBI Card">
                        <div class="w-100">
                          <div class="grow-card-img"><img loading="lazy" src="{{ base_path ~ directory }}/images/header/sbi-card-gyw.png" alt="SBI Card"></div>
                          <div class="grow-card-divider mx-2 my-1"></div>
                          <div class="grow-card-desc px-2 py-1 pb-3">{{ 'Customized Cards for unique business needs'|t }}</div>
                        </div>
                      </a>
                    </div>
                    <div class="col">
                      <a target="_blank" tabindex="0" class="grow-card p-1"
                        href="https://customer.sbiunipay.sbi.bank.in/CustomerPortal/quickPay"
                        aria-label="Redirect to SBI Unipay">
                        <div class="w-100">
                          <div class="grow-card-img"><img loading="lazy" src="{{ base_path ~ directory }}/images/header/sbi-unipay-gyw.png" alt="SBI Unipay"></div>
                          <div class="grow-card-divider mx-2 my-1"></div>
                          <div class="grow-card-desc px-2 py-1 pb-3">{{ 'Single platform for making bill payments anytime anywhere'|t }}</div>
                        </div>
                      </a>
                    </div>
                    <div class="col">
                        <a target="_blank" tabindex="0" class="grow-card p-1 " href="https://cmp.sbi.bank.in/Emandates" aria-label="Redirect to https://cmp.sbi.bank.in/Emandates">
                          <div class="w-100">
                              <div class="grow-card-img">
                                <strong class="">e-Mandate<br>(SBI FAST Plus)</strong><!----><!---->
                              </div>
                              <div class="grow-card-divider mx-2 my-1"></div>
                              <div class="grow-card-desc px-2 py-1 pb-3"> Digital version of mandate-based collection in your centralized pooling account </div>
                          </div>
                        </a>
                    </div>
                    <div class="col">
                        <a target="_blank" tabindex="0" class="grow-card p-1 " href="https://emudra.sbi.bank.in:8044/emudra/basic-details" aria-label="Redirect to https://emudra.sbi.bank.in:8044/emudra/basic-details">
                          <div class="w-100">
                              <div class="grow-card-img">
                                <strong class="">e-Mudra Loan</strong><!----><!---->
                              </div>
                              <div class="grow-card-divider mx-2 my-1"></div>
                              <div class="grow-card-desc px-2 py-1 pb-3">  Loans for new entrepreneurs </div>
                          </div>
                        </a>
                    </div>
                    <div class="col">
                        <a target="_blank" tabindex="0" class="grow-card p-1 " href="https://www.sbiloansin59minutes.com/home" aria-label="Redirect to https://www.sbiloansin59minutes.com/home">
                          <div class="w-100">
                              <div class="grow-card-img">
                                <strong class="">SME BRE Loan</strong><!----><!---->
                              </div>
                              <div class="grow-card-divider mx-2 my-1"></div>
                              <div class="grow-card-desc px-2 py-1 pb-3"> Business loans to large as well as medium and small business </div>
                          </div>
                        </a>
                    </div>
                    <div class="col">
                        <a target="_blank" tabindex="0" class="grow-card p-1 " href="https://cmp.yonobusiness.sbi.bank.in/emandate/#/mandateRegistration" aria-label="Redirect to https://cmp.yonobusiness.sbi.bank.in/emandate/#/mandateRegistration">
                          <div class="w-100">
                              <div class="grow-card-img">
                                <strong class="">e-Mandate<br>(SBI CMP NextGen)</strong><!----><!---->
                              </div>
                              <div class="grow-card-divider mx-2 my-1"></div>
                              <div class="grow-card-desc px-2 py-1 pb-3"> Digital version of mandate-based collection in your centralized pooling account </div>
                          </div>
                        </a>
                    </div>
                  </div>
                </div>
              </div>

              {# -- Right utility links -- #}
              <div class="col-12 col-md-4 col-lg-4 d-none d-lg-block p-0">
                <div class="right-menu float-end">
                  <div class="utility float-start">
                    <div class="Support float-start"><span tabindex="0">{{ 'Support'|t }}</span></div>
                    <div class="PersonalBanking float-start">
                      <a tabindex="0" title="{{ 'Personal Banking'|t }}" target="_blank" skiplocationchange="true" href="https://retail.sbi.bank.in/">{{ 'Personal Banking'|t }}</a>
                    </div>
                    <div class="CorporateBanking float-start">
                      <a tabindex="0" title="{{ 'Corporate Website'|t }}" target="_blank" skiplocationchange="true" href="https://sbi.bank.in/">{{ 'Corporate Website'|t }}</a>
                    </div>
                  </div>
                </div>
              </div>

            </div>{# /.row #}
          </div>{# /.container-xl #}
        </div>{# /.globalbar #}

        {# ── Main Header (Logo + CTA buttons) ──────────────────────── #}
        <div class="Main-header">
          <div class="Main-header_cta d-flex align-items-center">
            <div class="container-xl">
              <div class="row">
                <div class="col-7">
                  <a tabindex="0" href="{{ path('<front>') }}" title="{{ 'yono BUSINESS'|t }}" rel="external" class="md-margin-logo">
                    <span class="Main-header_cta_logo">
                      <img loading="lazy" alt="{{ 'Yono Business logo'|t }}" width="140px" height="38px"
                          src="{{ base_path ~ directory }}/images/yono_logo.png">
                    </span>
                  </a>
                </div>
                <div class="col-5 d-flex justify-content-end">
                  <div class="Main-header_cta_actionbuttons d-flex position-relative">

                    {# Open Current Account dropdown #}
                    <div class="d-md-inline-block d-xs-none d-sm-none d-none dropdown">
                      <div class="dropdown">
                        <button class="button prelogin secondary small d-block dropdown-toggle"
                                type="button" data-bs-toggle="dropdown" aria-expanded="false">
                          <div class="align-items-center button_inner d-flex justify-content-center">
                            <div class="content">{{ 'Open Current Account'|t }}</div>
                            <div class="arrow right"><img alt="" src="{{ base_path ~ directory }}/images/header/arrow-down-black.svg"></div>
                          </div>
                        </button>
                        <div class="current_account dropdown-menu">
                          <ul class="list-unstyled">
                            <li><a class="dropdown-item" href="#" title="{{ 'Current Account'|t }}">{{ 'Current Account'|t }}</a></li>
                            <li><a class="dropdown-item" href="#" title="{{ 'Current Account through Video KYC'|t }}">{{ 'Current Account through Video KYC'|t }}</a></li>
                            <li class="external"><a class="dropdown-item" href="#" title="{{ 'MCA Current Account'|t }}">{{ 'MCA Current Account'|t }}</a></li>
                          </ul>
                        </div>
                      </div>
                    </div>

                    {# Login / Logout #}
                    {% if logged_in %}
                      <div id="login-dropdown" class="d-inline-block ms-2">
                         <a href="{{ path('user.logout') }}" class="button prelogin primary small d-block" style="text-decoration: none;">
                          <div class="align-items-center button_inner d-flex justify-content-center">
                            <div class="content" style="color: #fff;">{{ 'Logout'|t }}</div>
                          </div>
                        </a>
                      </div>
                    {% else %}
                      <div id="login-dropdown" class="d-inline-block ms-2 dropdown">
                        <div class="dropdown">
                          <button class="button prelogin primary small d-block dropdown-toggle"
                                  type="" id="skipcon_text"
                                  data-bs-toggle="dropdown" data-bs-offset="0,0" aria-expanded="false">
                            <div class="align-items-center button_inner d-flex justify-content-center">
                              <div class="content">{{ 'Login'|t }}</div>
                              <div class="arrow right"><img alt="" src="{{ base_path ~ directory }}/images/header/arrow-down-white.svg"></div>
                            </div>
                          </button>
                          <div class="login-open dropdown-menu dropdown-menu-end">
                            <ul tabindex="-1" class="loginemnu">
                              <li id="loginOfmenu" tabindex="0" class="dropdown-item login" title="{{ 'Login'|t }}" onclick="window.location.href='{{ path('user.login') }}'">{{ 'Login'|t }}</li>
                              <li tabindex="0" class="dropdown-item newuser">{{ 'New User Activation'|t }}</li>
                              <li tabindex="0" class="dropdown-item register">{{ 'New Customer Registration'|t }}</li>
                              <li class="dropdown-item accounthelp" tabindex="0">
                                <span class="L_spacing2">{{ 'ACCOUNT HELP'|t }}</span>
                                <ul class="submenu">
                                  <li tabindex="0" class="list-group-item"><a href="javascript:void(0);" tabindex="-1">{{ 'Lock User Access'|t }}</a></li>
                                  <li tabindex="0" class="list-group-item"><a href="javascript:void(0);" tabindex="-1">{{ 'Unlock User Access'|t }}</a></li>
                                  <li tabindex="0" class="list-group-item"><a href="javascript:void(0);" tabindex="-1">{{ 'Enable or Disable IP Address'|t }}</a></li>
                                  <li tabindex="0" class="list-group-item"><a href="javascript:void(0);" tabindex="-1">{{ 'Register Mobile Number'|t }}</a></li>
                                  <li tabindex="0" class="list-group-item"><a href="javascript:void(0);" tabindex="-1">{{ 'Set Password Post Approval'|t }}</a></li>
                                  <li tabindex="0" class="list-group-item"><a href="javascript:void(0);" tabindex="-1">{{ 'Change State'|t }}</a></li>
                                </ul>
                              </li>
                            </ul>
                          </div>
                        </div>
                      </div>
                    {% endif %}

                  </div>
                </div>
              </div>{# /.row #}
            </div>{# /.container-xl #}
          </div>{# /.Main-header_cta #}

          {# ── Navigation Bar ──────────────────────────────────────── #}
          <div class="Main-header_menu">
            <div class="container-xl bg_mobile">
              <nav class="navbar navbar-expand-lg p-0" role="navigation" aria-label="{{ 'Main navigation'|t }}">
                <div class="container-fluid p-0">
                  <button type="button"
                          data-bs-toggle="collapse"
                          data-bs-target="#navbar-content"
                          aria-controls="navbar-content"
                          aria-expanded="false"
                          aria-label="{{ 'Toggle navigation'|t }}"
                          class="navbar-toggler">
                    <span class="navbar-toggler-icon"></span>
                  </button>

                  <div id="navbar-content" class="collapse navbar-collapse main_nav mobile-margin">

                    {# Mobile: Open Current Account button #}
                    <div class="d-block d-lg-none d-md-none my-3 dropdown">
                      <button type="button" id="dropdownBasic1"
                              class="dropdown-toggle hollowbutton CA_btn" data-bs-toggle="dropdown" aria-expanded="false">
                        {{ 'Open Current Account'|t }}
                      </button>
                      <div class="current_account CA_dropdown dropdown-menu" data-bs-popper="static">
                        <ul class="list-unstyled">
                          <li><a target="_Blank" rel="noreferrer" title="{{ 'Current Account'|t }}" class="dropdown-item" href="https://corp.sbi.bank.in/oaorevamp/oaolanding.htm">{{ 'Current Account'|t }}</a></li>
                          <li><a target="_Blank" title="{{ 'Current Account through Video KYC'|t }}" class="dropdown-item" href="https://corp.sbi.bank.in/vkyccao/vkycoaolanding.htm">{{ 'Current Account through Video KYC'|t }}</a></li>
                          <li class="external"><a target="_Blank" title="{{ 'MCA Current Account'|t }}" class="dropdown-item" href="https://corp.sbi.bank.in/mcaoao/mcaaccopening.htm">{{ 'MCA Current Account'|t }}</a></li>
                        </ul>
                      </div>
                    </div>

                    {# Mobile Accordion Nav (L1) #}
                    <div class="L1Accord d-block d-lg-none accordion" id="port-accordion">
                      {# Accounts #}
                      <div class="accordion-item">
                        <h2 class="accordion-header" id="accordion-header-one">
                          <button class="accordion-button collapsed" type="button"
                                  data-bs-toggle="collapse" data-bs-target="#collapse-one"
                                  aria-expanded="false" aria-controls="collapse-one">
                            {{ 'Accounts'|t }}
                          </button>
                        </h2>
                        <div id="collapse-one" class="accordion-collapse collapse"
                            aria-labelledby="accordion-header-one" data-bs-parent="#port-accordion">
                          <div class="accordion-body" data-hotspot="1">
                            <div class="L2Accord accordion" id="country-accordion-one">
                              <div class="accordion-item">
                                <h2 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-reg-ca">{{ 'Regular Current Account'|t }}</button></h2>
                                <div id="collapse-reg-ca" class="accordion-collapse collapse" data-bs-parent="#country-accordion-one">
                                  <div class="accordion-body">
                                    <div class="row">
                                      <div class="mb-4 mobile-pad"><div><strong>{{ 'Regular Current Account'|t }}</strong></div><div>{{ 'Enjoy a full range of essential banking facilities'|t }}</div></div>
                                    </div>
                                  </div>
                                </div>
                              </div>
                              <div class="accordion-item">
                                <h2 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-prem-ca">{{ 'Premium Current Accounts'|t }}</button></h2>
                                <div id="collapse-prem-ca" class="accordion-collapse collapse" data-bs-parent="#country-accordion-one">
                                  <div class="accordion-body">
                                    <div class="row">
                                      <div class="mb-4 mobile-pad"><div><strong>{{ 'Silver Current Account'|t }}</strong></div><div>{{ 'Perfect for day to day business, with more benefits'|t }}</div></div>
                                      <div class="mb-4 mobile-pad"><div><strong>{{ 'Gold Current Account'|t }}</strong></div><div>{{ 'For businesses looking to expand and diversify'|t }}</div></div>
                                      <div class="mb-4 mobile-pad"><div><strong>{{ 'Diamond Current Account'|t }}</strong></div><div>{{ 'For businesses looking for premium features'|t }}</div></div>
                                      <div class="mb-4 mobile-pad"><div><strong>{{ 'Platinum Current Account'|t }}</strong></div><div>{{ 'For businesses looking for premier banking services'|t }}</div></div>
                                      <div class="mb-4 mobile-pad"><div><strong>{{ 'Palladium Current Account'|t }}</strong></div><div>{{ 'Your Business meets Privilege'|t }}</div></div>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>
                            <div class="row menu_footer mt-3">
                              <div class="col-12"><div class="row border-top">
                                <div class="col-12 pb-4 pt-2">
                                  <ul class="list-unstyled">
                                    <li><a href="javascript:void(0);" tabindex="0" class="compare">
                                      <span class="icon_place"><img loading="lazy" src="{{ base_path ~ directory }}/images/header/compare-icon.svg"></span>{{ 'Compare Current Accounts'|t }}
                                    </a></li>
                                  </ul>
                                </div>
                              </div></div>
                            </div>
                          </div>
                        </div>
                      </div>

                      {# Digital Solutions #}
                      <div class="accordion-item">
                        <h2 class="accordion-header" id="accordion-header-2">
                          <button class="accordion-button collapsed" type="button"
                                  data-bs-toggle="collapse" data-bs-target="#collapse-2"
                                  aria-expanded="false" aria-controls="collapse-2">
                            {{ 'Digital Solutions'|t }}
                          </button>
                        </h2>
                        <div id="collapse-2" class="accordion-collapse collapse"
                            aria-labelledby="accordion-header-2" data-bs-parent="#port-accordion">
                          <div class="accordion-body">
                            <div class="row">
                              <div class="mb-2 mt-2"><div><strong>{{ 'yono Business (YB) / Corporate INB'|t }}</strong></div><div>{{ 'Manage accounts, transactions and banking operations online'|t }}</div></div>
                              <div class="mb-2 mt-2"><div><strong>{{ 'Trade Finance (eTrade)'|t }}</strong></div><div>{{ 'Apply for LCs &amp; BGs digitally'|t }}</div></div>
                              <div class="mb-2 mt-2"><div><strong>{{ 'Forex (eForex)'|t }}</strong></div><div>{{ 'User friendly online platform to book foreign exchange'|t }}</div></div>
                              <div class="mb-2 mt-2"><div><strong>{{ 'Cash Management Product (CMP)'|t }}</strong></div><div>{{ 'Manage your cash flow, liquidity and financial operations efficiently'|t }}</div></div>
                              <div class="mb-2 mt-2"><div><strong>{{ 'Supply Chain Finance (SCF)'|t }}</strong></div><div>{{ 'Managing supply chain by providing working capital and improving liquidity'|t }}</div></div>
                            </div>
                            <div class="row menu_footer mt-3">
                              <div class="col-12"><div class="row border-top">
                                <div class="col-12 pb-4 pt-2">
                                  <div><a href="javascript:void(0);" tabindex="0" class="menu_link">{{ 'View All Digital Solutions'|t }}</a></div>
                                </div>
                              </div></div>
                            </div>
                          </div>
                        </div>
                      </div>

                      {# Trade Finance #}
                      <div class="accordion-item">
                        <h2 class="accordion-header" id="accordion-header-3">
                          <button class="accordion-button collapsed" type="button"
                                  data-bs-toggle="collapse" data-bs-target="#collapse-3"
                                  aria-expanded="false" aria-controls="collapse-3">
                            {{ 'Trade Finance'|t }}
                          </button>
                        </h2>
                        <div id="collapse-3" class="accordion-collapse collapse"
                            aria-labelledby="accordion-header-3" data-bs-parent="#port-accordion">
                          <div class="accordion-body">
                            <div class="row">
                              <div class="mb-2 mt-2"><div><strong>{{ 'Inland Letter of Credit (LC) Issuance'|t }}</strong></div></div>
                              <div class="mb-2 mt-2"><div><strong>{{ 'Import Letter of Credit (LC) Issuance'|t }}</strong></div></div>
                              <div class="mb-2 mt-2"><div><strong>{{ 'Export LC / Non-LC Bills Collection'|t }}</strong></div></div>
                              <div class="mb-2 mt-2"><div><strong>{{ 'Inland Bank Guarantee'|t }}</strong></div></div>
                              <div class="mb-2 mt-2"><div><strong>{{ 'Electronic BG (eBG)'|t }}</strong></div></div>
                            </div>
                          </div>
                        </div>
                      </div>

                      {# Forex & Treasury #}
                      <div class="accordion-item">
